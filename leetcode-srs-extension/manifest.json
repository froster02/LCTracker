{
  "manifest_version": 3,
  "name": "LeetCode Galaxy Tracker",
  "version": "3.0.0",
  "description": "Automatically track LeetCode submissions with rich analytics and offline support.",
  "permissions": [
    "storage",
    "identity",
    "alarms",
    "scripting",
    "notifications"
  ],
  "host_permissions": [
    "*://leetcode.com/*",
    "*://*.leetcode.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["*://leetcode.com/*", "*://*.leetcode.com/*"],
      "js": ["content.js"],
      "run_at": "document_end"
    },
    {
      "matches": ["*://leetcode.com/*", "*://*.leetcode.com/*"],
      "js": ["content-main.js"],
      "run_at": "document_start",
      "world": "MAIN"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon.png",
      "48": "icon.png",
      "128": "icon.png"
    }
  },
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "oauth2": {
    "client_id": "YOUR_GOOGLE_CLIENT_ID",
    "scopes": ["openid", "email", "profile"]
  }
}
